{$API_DOMAIN} {
	encode zstd gzip
	request_body {
		max_size 1MB
	}

	@internal_mcp path /mcp /mcp/*
	respond @internal_mcp 404

	reverse_proxy api:8000

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		-Server
	}
}
