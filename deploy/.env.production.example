API_DOMAIN=api.agentpulse.cc
AGENTPULSE_IMAGE=ghcr.io/clycheng/agentpulse-api:latest

# Supabase Session Pooler connection string. Keep sslmode=require.
AGENTPULSE_DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# Generate with: openssl rand -hex 32
AGENTPULSE_AUTH_SECRET_KEY=replace-with-a-long-random-secret
AGENTPULSE_CREDENTIAL_ENCRYPTION_KEY=replace-with-an-independent-random-secret

# JSON is required for pydantic-settings list parsing.
AGENTPULSE_CORS_ORIGINS=["app://agentpulse","https://agentpulse.cc","https://www.agentpulse.cc"]

# Used by deploy/backup-postgres.sh, not read by the application.
BACKUP_ENCRYPTION_KEY=replace-with-a-separate-long-random-secret

# Optional TD-10 provider configuration remains per employee in the app.
AGENTPULSE_RESEND_BASE_URL=https://api.resend.com
